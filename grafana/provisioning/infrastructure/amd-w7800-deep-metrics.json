  "panels": [
    {
      "type": "row",
      "title": "Clock Frequencies",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": true, "drawStyle": "line", "lineInterpolation": "smooth" },
          "unit": "rotMHz", "min": 0
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Max clock" }, "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }, { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Min clock" }, "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }, { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "GPU Clock (SCLK) — Current vs Limits",
      "type": "timeseries",
      "targets": [
        { "expr": "max(gpu_clock)", "legendFormat": "Current clock", "refId": "A" },
        { "expr": "max(gpu_max_clock)", "legendFormat": "Max clock", "refId": "B" },
        { "expr": "max(gpu_min_clock)", "legendFormat": "Min clock", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": true, "drawStyle": "line", "lineInterpolation": "smooth" },
          "unit": "percent", "min": 0, "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Clock Utilization — SCLK Headroom",
      "type": "timeseries",
      "targets": [
        { "expr": "max(gpu_clock) / max(gpu_max_clock) * 100", "legendFormat": "SCLK utilization %", "refId": "A" }
      ]
    },
    {
      "type": "row",
      "title": "Thermal Curves",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "collapsed": false
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2, "spanNulls": true, "drawStyle": "line", "lineInterpolation": "smooth", "gradientMode": "scheme" },
          "unit": "celsius", "min": 0
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Junction" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Edge" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Memory" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Temperature Curves — All Sensors",
      "type": "timeseries",
      "targets": [
        { "expr": "max(gpu_junction_temperature)", "legendFormat": "Junction", "refId": "A" },
        { "expr": "max(gpu_edge_temperature)", "legendFormat": "Edge", "refId": "B" },
        { "expr": "max(gpu_memory_temperature)", "legendFormat": "Memory", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": true, "drawStyle": "line", "lineInterpolation": "smooth" },
          "unit": "celsius", "min": 0
        },
