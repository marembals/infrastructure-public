      "targets": [
        { "expr": "max(gpu_junction_temperature) - max(gpu_edge_temperature)", "legendFormat": "Junction−Edge delta", "refId": "A" },
        { "expr": "max(gpu_junction_temperature) - max(gpu_memory_temperature)", "legendFormat": "Junction−Memory delta", "refId": "B" }
      ]
    },
    {
      "type": "row",
      "title": "Power & Energy",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 102,
      "collapsed": false
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
