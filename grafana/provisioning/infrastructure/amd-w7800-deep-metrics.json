        { "expr": "avg_over_time(max(gpu_average_package_power)[5m:])", "legendFormat": "5m avg power (W)", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
